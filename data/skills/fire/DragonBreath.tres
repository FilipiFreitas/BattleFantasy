[gd_resource type="Resource" script_class="SkillResource" load_steps=5 format=3]

[ext_resource type="Script" path="res://src/core/skills/effects/DamageEffect.gd" id="1_dmg"]
[ext_resource type="Script" path="res://src/core/skills/targeters/AreaTargeter.gd" id="2_target"]
[ext_resource type="Script" path="res://src/core/skills/SkillResource.gd" id="3_skill"]

[sub_resource type="Resource" id="Resource_1"]
script = ExtResource("1_dmg")
damage_value = 45
element = "fire"

[sub_resource type="Resource" id="Resource_2"]
script = ExtResource("2_target")
area_pattern = 0 # TOTAL
target_type = 1  # ALL
target_side = 0  # ENEMIES

[resource]
script = ExtResource("3_skill")
skill_name = "Dragon Breath"
description = "Cospe chamas devastadoras que atingem todos os inimigos."
targeter = SubResource("Resource_2")
effects = Array[Resource("res://src/core/skills/effects/BaseEffect.gd")]([SubResource("Resource_1")])
